generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USER DOMAIN
// ==========================================

model User {
  id             String         @id @default(uuid())
  name           String?
  email          String         @unique
  password       String?
  role           Role           @default(USER)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  isVerified     Boolean        @default(false) @map("is_verified")
  lastLogin      DateTime?      @map("last_login")
  otp            String?
  otpExpires     DateTime?      @map("otp_expires")
  phone          String?        @unique
  isActive       Boolean        @default(true) @map("is_active")

  // Relations
  addresses      Address[]
  cartItems      Cart[]
  loginHistories LoginHistory[]
  measurement    Measurement?
  orders         Order[]
  sessions       Session[]
  reviews        Review[]
  activities     UserActivity[]
  wishlist       Wishlist[]

  @@map("users")
  @@index([email])
}

model Address {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  label     String
  line1     String
  line2     String?
  city      String
  state     String
  pincode   String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@map("user_addresses")
  @@index([userId])
}

model Measurement {
  id                 String    @id @default(uuid())
  userId             String    @unique @map("user_id")
  chest              Float?
  waist              Float?
  shoulder           Float?
  neck               Float?
  sleeve             Float?
  inseam             Float?
  height             String?
  lowerBodyShape     String?   @map("lower_body_shape")
  preferredFit       String?   @map("preferred_fit")
  shoulderType       String?   @map("shoulder_type")
  upperBodyShape     String?   @map("upper_body_shape")
  notificationSentAt DateTime? @map("notification_sent_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_measurements")
}

model Session {
  id        String   @id @default(uuid())
  token     String
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
  @@index([userId])
}

model LoginHistory {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  loginAt   DateTime  @default(now()) @map("login_at")
  logoutAt  DateTime? @map("logout_at")
  ipAddress String?   @map("ip_address")
  device    String?
  
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_login_history")
  @@index([userId])
}

model UserActivity {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity")
  @@index([userId])
}

// ==========================================
// COMMERCE DOMAIN
// ==========================================

model Product {
  id               String      @id @default(uuid())
  name             String?
  title            String?
  description      String?
  price            Decimal
  images           String[]    @default([])
  stock            Int         @default(0)
  isActive         Boolean     @default(true) @map("is_active")
  inStock          Boolean     @default(true) @map("in_stock")
  categoryId       String?     @map("category_id")
  colors           String[]    @default([])
  details          String[]    @default([])
  displayLocations String[]    @default(["Category PLP"]) @map("display_locations")
  occasions        String[]    @default([])
  sizes            String[]    @default([])
  fabric           String?
  videoUrl         String?     @map("video_url")
  externalLink     String?     @map("external_link")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  category         Category?   @relation(fields: [categoryId], references: [id])
  cartItems        Cart[]
  orderItems       OrderItem[]
  reviews          Review[]
  wishlist         Wishlist[]

  @@map("products")
  @@index([categoryId])
}

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  image       String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products    Product[]

  @@map("categories")
}

model Cart {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  productId   String   @map("product_id")
  quantity    Int      @default(1)
  isAbandoned Boolean  @default(false) @map("is_abandoned")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("carts")
  @@index([userId])
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("wishlists")
}

model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  rating    Int      @default(5)
  comment   String?
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("product_reviews")
}

// ==========================================
// ORDER DOMAIN
// ==========================================

model Order {
  id                String      @id @default(uuid())
  userId            String      @map("user_id")
  total             Decimal
  status            OrderStatus @default(PENDING)
  razorpayOrderId   String?     @unique @map("razorpay_order_id")
  razorpayPaymentId String?     @unique @map("razorpay_payment_id")
  shippingAddressId String?     @map("shipping_address_id")
  trackingId        String?     @map("tracking_id")
  courierPartner    String?     @map("courier_partner")
  invoiceUrl        String?     @map("invoice_url")
  shippedAt         DateTime?   @map("shipped_at")
  deliveredAt       DateTime?   @map("delivered_at")
  estimatedDelivery DateTime?   @map("estimated_delivery")
  productionStage   String?     @default("Pending") @map("production_stage")
  trackingNotes     String?     @map("tracking_notes")
  adminNotes        String?     @map("admin_notes")
  orderNumber       String?     @unique @map("order_number")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shippingAddress   Address?    @relation(fields: [shippingAddressId], references: [id])
  orderItems        OrderItem[]

  @@map("orders")
  @@index([userId])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String  @map("order_id")
  productId     String  @map("product_id")
  quantity      Int
  price         Decimal
  color         String?
  size          String?
  customization Json?
  
  order         Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("order_items")
  @@index([orderId])
}

model PromoCode {
  id         String       @id @default(uuid())
  code       String       @unique
  discount   Decimal
  type       DiscountType @default(PERCENTAGE)
  isActive   Boolean      @default(true) @map("is_active")
  usageLimit Int?         @default(100) @map("usage_limit")
  usedCount  Int          @default(0) @map("used_count")
  expiresAt  DateTime?    @map("expires_at")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@map("promo_codes")
}

// ==========================================
// CMS DOMAIN
// ==========================================

model CMSPage {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("cms_pages")
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  USER
  ADMIN
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum OrderStatus {
  PENDING
  PAID
  CONFIRMED
  TAILORING
  QUALITY_CHECK
  SHIPPED
  DELIVERED
  CANCELLED
}
