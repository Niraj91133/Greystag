{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/cron",
            "destination": "/api/cron.js"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.js"
        }
    ],
    "crons": [
        {
            "path": "/api/cron",
            "schedule": "*/30 * * * *"
        }
    ]
}